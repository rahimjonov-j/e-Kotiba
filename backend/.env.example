NODE_ENV=development
PORT=8080

# Frontend origin(s)
APP_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# UzbekVoice
UZBEKVOICE_STT_URL=https://uzbekvoice.ai/api/v1/stt
UZBEKVOICE_STT_API_KEY=your_uzbekvoice_stt_api_key
UZBEKVOICE_TTS_URL=https://uzbekvoice.ai/api/v1/tts
UZBEKVOICE_TTS_API_KEY=your_uzbekvoice_tts_api_key
CBU_EXCHANGE_RATES_URL=https://cbu.uz/en/arkhiv-kursov-valyut/json/

# Scheduler
REMINDER_JOB_CRON=*/1 * * * *
MEETING_JOB_CRON=*/5 * * * *
MEETING_AUDIO_REMINDER_CRON=*/1 * * * *

# Session auth
SESSION_TTL_HOURS=720
SESSION_COOKIE_NAME=kotiba_session
